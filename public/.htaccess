<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the requested URL is an actual physical file or directory, serve it normally
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Otherwise, route everything else to your PWA index router
  RewriteRule . /index.html [L]
</IfModule>
